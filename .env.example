# WS Service - Environment Variables Example
# Copy this file and fill in your values.
# These env vars override config/development.yaml or config/production.yaml
# via config/custom-environment-variables.yaml

# Server
PORT=5504

# Kafka
KAFKA_BROKER=["localhost:9092"]
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# CORS - Allowed frontend origins (for WebSocket CORS)
CLIENT_UI_DOMAIN=http://localhost:5173
ADMIN_UI_DOMAIN=http://localhost:5174
